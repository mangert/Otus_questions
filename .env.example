# Documents build-time and runtime settings used by Docker Compose.

# Build-time: baked into the Vite bundle; changing it requires rebuilding frontend.
VITE_API_URL=/api

# Runtime: host port mapped to the Nginx frontend container.
FRONTEND_PORT=8081

# Runtime: optional comma-separated origins for direct cross-origin backend access.
# Leave empty for the same-origin Docker flow through Nginx at /api.
CORS_ORIGINS=
